# Backend
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database (PostgreSQL for Docker)
POSTGRES_DB=smartiktg
POSTGRES_USER=smartiktg
POSTGRES_PASSWORD=smartiktg_pass
DATABASE_URL=postgresql+psycopg2://smartiktg:smartiktg_pass@postgres:5432/smartiktg

# CORS (comma-separated list for production domains)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin auth rate-limit
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_BLOCK_SECONDS=300

# Bot
TELEGRAM_BOT_TOKEN=CHANGE_ME
BACKEND_URL=http://backend:8000
# Shared token for bot -> backend service calls
BOT_API_TOKEN=CHANGE_ME
# Optional: chat/group for lead notifications (e.g. -1001234567890 or @channel_username)
TELEGRAM_LEADS_CHAT_ID=

# Admin panel (Vite)
VITE_API_URL=http://localhost:8000
