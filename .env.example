# Backend
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database (PostgreSQL for Docker)
POSTGRES_DB=smartiktg
POSTGRES_USER=smartiktg
POSTGRES_PASSWORD=smartiktg_pass
DATABASE_URL=postgresql+psycopg2://smartiktg:smartiktg_pass@postgres:5432/smartiktg

# CORS (comma-separated list for production domains)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin auth rate-limit
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_BLOCK_SECONDS=300

# Bot
TELEGRAM_BOT_TOKEN=123456789:replace-with-telegram-bot-token
BOT_DELIVERY_MODE=polling
BACKEND_URL=http://backend:8000
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=smartiktg
BOT_STATE_TTL_SECONDS=86400
BOT_REMINDER_STATE_TTL_SECONDS=172800
BOT_MEDIA_FILE_ID_TTL_SECONDS=2592000
BOT_MEMORY_CACHE_TTL_SECONDS=60
TELEGRAM_WEBHOOK_BASE_URL=https://example.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-webhook-secret
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false
# Shared token for bot -> backend service calls
BOT_API_TOKEN=replace-with-shared-internal-token
# Optional: chat/group for lead notifications (e.g. -1001234567890 or @channel_username)
TELEGRAM_LEADS_CHAT_ID=-1001234567890

# Admin panel (Vite)
VITE_API_URL=http://localhost:8000
